<!DOCTYPE html>
<html>
    <head>
        <title>LabMate - Laboratories</title>
        <link rel="icon" type="image/x-icon" href="/img/favicon.ico">
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <link rel="stylesheet" href="/css/pop-up.css">
        <link rel="stylesheet" href="/css/theme-style.css">
        <link rel="stylesheet" href="/css/navbar-style.css">
        <link rel="stylesheet" href="/css/profile-modal.css">
        <link rel="stylesheet" href="/css/student-laboratories.css">
        <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,500,0,0">
    </head>

    <body class="laboratories-view">
        {{>navbar}}

        <div class="frame">
            <main class="labs-shell">
                <aside class="labs-sidebar">
                    <div class="sidebar-intro">
                        <span class="sidebar-kicker">{{pageHeading}}</span>
                        <h1>Laboratory Selection</h1>
                        <p>Choose a room, inspect each seat's bookings, and complete the reservation from one workspace.</p>
                    </div>

                    <div class="visually-hidden-control">
                        <label for="labs">Laboratory</label>
                        <select name="labs" id="labs">
                            {{#each labs}}
                                <option value="{{this._id}}" data-room="{{this.room}}" data-hall="{{this.hall}}" data-capacity="{{this.capacity}}" {{#if @first}}selected{{/if}}>
                                    {{this.room}} | {{this.hall}}
                                </option>
                            {{else}}
                                <option value="" disabled selected>No laboratories available</option>
                            {{/each}}
                        </select>
                    </div>

                    <div class="lab-option-list" id="lab-option-list">
                        {{#each labs}}
                            <button type="button" class="lab-option {{#if @first}}is-active{{/if}}" data-lab-id="{{this._id}}" data-room="{{this.room}}" data-hall="{{this.hall}}" data-capacity="{{this.capacity}}">
                                <span class="material-symbols-outlined lab-option__icon" aria-hidden="true">biotech</span>
                                <span class="lab-option__content">
                                    <span class="lab-option__name">{{this.room}}</span>
                                    <span class="lab-option__meta">{{this.hall}} | {{this.capacity}} seats</span>
                                </span>
                            </button>
                        {{else}}
                            <div class="sidebar-empty-state">No laboratories are configured yet.</div>
                        {{/each}}
                    </div>

                    <div class="sidebar-actions">
                        <button type="button" class="sidebar-filter" disabled>
                            <span class="material-symbols-outlined" aria-hidden="true">tune</span>
                            <span>Filter Equipment</span>
                        </button>

                        <div class="sidebar-links">
                            <button type="button" class="sidebar-link" disabled>
                                <span class="material-symbols-outlined" aria-hidden="true">construction</span>
                                <span>Maintenance Status</span>
                            </button>
                            <button type="button" class="sidebar-link" disabled>
                                <span class="material-symbols-outlined" aria-hidden="true">help</span>
                                <span>Support</span>
                            </button>
                        </div>
                    </div>
                </aside>

                <section class="labs-main">
                    {{#if success}}
                        <div class="success-banner">Your reservation has been successfully created.</div>
                    {{/if}}

                    <header class="labs-main__header">
                        <div class="labs-main__header-copy">
                            <span class="section-kicker">Live Seat Planner</span>
                            <h2 id="selected-lab-name">Select a laboratory</h2>
                            <p id="selected-lab-meta">Choose a room from the left to view capacity and availability details.</p>
                        </div>

                        <div id="legend">
                            <div class="legend-item"><div id="legend-available"></div><span class="legend-text">Available</span></div>
                            <div class="legend-item"><div id="legend-selected"></div><span class="legend-text">Selected</span></div>
                            <div class="legend-item"><div id="legend-unavailable"></div><span class="legend-text">Fully Booked</span></div>
                            <div class="legend-item"><div id="legend-booking"></div><span class="legend-text">Your Booking</span></div>
                        </div>
                    </header>

                    <div class="labs-main__controls">
                        <div class="dashboard-control">
                            <label class="dashboard-control__label" for="dates">Reservation Date</label>
                            <select name="dates" id="dates">
                                {{#each next7Days}}
                                    <option value="{{this.formattedDate}}" {{#if @first}}selected{{/if}}>{{this.displayDate}}</option>
                                {{/each}}
                            </select>
                        </div>

                        <button id="view-button" type="button">Load Availability</button>
                    </div>

                    <section id="chart" class="availability-card">
                        <div class="availability-card__header">
                            <div>
                                <span class="section-kicker">Seat Availability</span>
                                <h3 id="chart-header">Seat map</h3>
                            </div>
                            <p class="availability-card__hint">Hover a seat to inspect bookings, then select it to choose a start and end time.</p>
                        </div>

                        <div id="chart-body">
                            <div id="timetable" class="seat-grid" aria-live="polite"></div>
                        </div>
                    </section>

                    <div class="labs-main__bottom">
                        <section class="schedule-card">
                            <div class="card-heading">
                                <h3><span class="material-symbols-outlined" aria-hidden="true">schedule</span><span>Reservation Setup</span></h3>
                                <p>Pick a seat first, choose a start time, then extend the session to the latest available end time.</p>
                            </div>

                            <div class="schedule-grid">
                                <div class="dashboard-control">
                                    <label class="dashboard-control__label" for="starttimes">Start Time</label>
                                    <select name="starttimes" id="starttimes">
                                        <option value="" disabled selected>Select a Seat First</option>
                                    </select>
                                </div>

                                <div class="dashboard-control">
                                    <label class="dashboard-control__label" for="endtimes">Reserve Until</label>
                                    <select name="endtimes" id="endtimes">
                                        <option value="" disabled selected>Select a Start Time First</option>
                                    </select>
                                </div>

                                <div class="selection-chip-group">
                                    <div class="selection-chip" id="selected-seat-chip">Seat: Not selected</div>
                                    <div class="selection-chip" id="selected-time-chip">Start: Not selected</div>
                                </div>
                            </div>

                            {{#if allowAnonymous}}
                                <label id="anonymous-option" class="anonymous-toggle">
                                    <input type="checkbox" id="anonymous" name="anonymous">
                                    <span class="toggle-track" aria-hidden="true"></span>
                                    <span class="toggle-label">Anonymous booking</span>
                                </label>
                            {{/if}}

                            <div class="schedule-note">
                                <span class="material-symbols-outlined" aria-hidden="true">info</span>
                                <p>
                                    {{#if isWalkInMode}}
                                        Walk-in reservations are logged under your account until the student is checked in on-site.
                                    {{else}}
                                        Evening sessions may require an accompanying registered student depending on laboratory policy.
                                    {{/if}}
                                </p>
                            </div>
                        </section>

                        <section class="summary-card">
                            <div class="card-heading">
                                <h3>Summary</h3>
                                <p>Review the current selection before creating the booking.</p>
                            </div>

                            <div class="summary-list">
                                <div class="summary-item"><span>Laboratory</span><strong id="summary-lab">Not selected</strong></div>
                                <div class="summary-item"><span>Date</span><strong id="summary-date">Not selected</strong></div>
                                <div class="summary-item"><span>Seat</span><strong id="summary-seat">Not selected</strong></div>
                                <div class="summary-item"><span>Start Time</span><strong id="summary-start">Not selected</strong></div>
                                <div class="summary-item"><span>End Time</span><strong id="summary-end">Not selected</strong></div>
                                <div class="summary-item"><span>Duration</span><strong id="summary-duration">Select a start and end time</strong></div>
                            </div>

                            <button id="reserve-button" type="button" disabled>{{reserveButtonLabel}}</button>
                            <p class="summary-footnote">{{missingSelectionMessage}}</p>
                        </section>
                    </div>
                </section>
            </main>

            <footer class="labs-footer">
                <span class="labs-footer__brand">LabMate</span>
                <span class="labs-footer__copy">Seat reservation dashboard for laboratory sessions.</span>
            </footer>
        </div>

        <div id="overlay" class="overlay"></div>
        {{> profile-modal}}
        <div id="seat-hover-card" class="seat-hover-card" hidden></div>

        <div class="container">
            <div class="popup" id="confirm-popup">
                <img src="img/reservation.png" class="icon" alt="Reservation confirmation icon">
                <p class="message">Would you like to proceed with your reservation?</p>
                <div class="btn-wrapper"><button type="button" class="btn1" id="confirm-cancel-button">Cancel</button></div>
                <div class="btn-wrapper"><button type="button" class="btn2" id="confirm-submit-button">Confirm</button></div>
            </div>
        </div>

        <form id="reservationForm" action="{{reservationAction}}" method="POST" style="display: none;">
            <input type="hidden" id="labId" name="labId" value="">
            <input type="hidden" id="date" name="date" value="">
            <input type="hidden" id="seatNumber" name="seatNumber" value="">
            <input type="hidden" id="startTime" name="startTime" value="">
            <input type="hidden" id="endTime" name="endTime" value="">
            <input type="hidden" id="userId" name="userId" value="{{user._id}}">
            <input type="hidden" id="isAnonymous" name="isAnonymous" value="">
        </form>

        <script>
            window.LABORATORIES_PAGE_CONFIG = {
                userId: "{{user._id}}",
                missingSelectionMessage: "{{missingSelectionMessage}}",
                isWalkInMode: {{#if isWalkInMode}}true{{else}}false{{/if}}
            };
        </script>
        <script src="/js/laboratories-page.js"></script>
        <script src="/js/profile-modal.js"></script>
    </body>
</html>
