<!DOCTYPE html>
<html>
    <head>
        <title>LabMate - Forgot Password</title> 
        <link rel="icon" type="image/x-icon" href="/img/favicon.ico">
        
        <meta charset = "UTF-8">
        <meta name = "viewport" content = "width=device-width, initial-scale=1.0">

        <link rel="stylesheet" href="/css/theme-style.css">
        <link rel="stylesheet" href="/css/navbar-style.css">
        <link rel="stylesheet" href="/css/signin-page.css">
        
        <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    </head>
    <body>
        
        {{> navbar-signedout}}

        <form action ="/resetpassword" method="post" id="container">
            <div id="signin"> 
                <div class="left-column">
                    <h1>Forgot Password</h1>
                    <p id="error">{{#if error}}{{error}}{{/if}}</p>
                    <div class="inputWrapper">
                        <label for="email">Email</label>
                        <input type="email" name="email" required>
                    </div>
                    <div class="inputWrapper">
                        <label for="secAns">Security Question: What is your mother's maiden name?</label>
                        <input type="password" name="secAns" required>
                    </div>
                    
                    <input id="signin-btn" type="submit" value="Submit">
                </div>

                <div class="right-column">
                    <img src="/img/sign-in-graphic.png">
                </div>
            </div>
        </form>

        <script>
            document.getElementById("container").addEventListener("submit", async function(e) {
                e.preventDefault();
                
                const formData = new FormData(this);
                const errorDiv = document.getElementById("error");

                /* if (formData.get("secAns")) {
                    errorDiv.textContent = "Input read.";
                    return;
                } */
                
                try { 
                    const response = await fetch("/resetpassword", {
                        method: "POST",
                        headers: {
                            "Content-Type": "application/json",
                        },
                        body: JSON.stringify({
                            email: formData.get("email"),
                            securityQuestion: formData.get("secAns")
                        })
                    })
                    .then((response) => response.json())
                    .then((data) => {
                        if (data.success) {
                            alert(data.message);
                        } else {
                            alert(data.message || "Failed to reset password. Please try again.");
                        }
                    })
                    .catch((error) => {
                        console.error("Error:", error);
                        alert("An error occurred while resetting the password.");
                    });

                    /*
                    if (response.ok) {
                        errorDiv.textContent = "Success.";
                        alert(response.message);
                    } else {
                        errorDiv.textContent = "Failure.";
                        alert(response.message);
                    } */
                        

                    /* temporarily store userid in localstorage so app doesnt break
                    if (response.ok) {
                        const sessionResponse = await fetch("/api/session");
                        /* const sessionData = await sessionResponse.json();
                        
                        if (sessionData.user) {
                            localStorage.setItem("userId", sessionData.user._id);
                            localStorage.setItem("isLabtech", (sessionData.user.type === "LabTech").toString());
                        } 
                    }

                    // follow redirect
                    if (response.redirected) {
                        window.location.href = response.url;
                        return;
                    }

                    const data = await response.json();
                    
                    // display error from server if meron
                    if (!response.ok) {
                        errorDiv.textContent = data.error;
                        errorDiv.style.display = "block";
                    } */
                    //errorDiv.textContent = "Success.";
                } catch (error) {
                    console.error("Error during password recovery:", error);
                    errorDiv.textContent = "An error occurred. Please try again.";
                    errorDiv.style.display = "block";
                }
            });
        </script>
        
    </body>
    
</html> 
